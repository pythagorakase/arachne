.DS_Store
__pycache__/
*.py[cod]

# Published decision pages are runtime content, not application source.
pages/*.html
pages/.meta/
!pages/.gitkeep

# Rulings and cursors must never enter source control.
rulings/
.arachne-state/
auth-token

# Local test and tooling state.
.venv/
.coverage
.pytest_cache/
