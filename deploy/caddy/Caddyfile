# Arachne custom-domain ingress — tailnet-only by construction.
#
# Replace every @@...@@ placeholder before installing at /etc/caddy/Caddyfile:
#   @@TAILNET_IPV4@@       cairn's Tailscale address (`tailscale ip -4`)
#   @@ARACHNE_CA_FILE@@    the private localhost CA bundle Arachne's TLS uses,
#                          e.g. /home/<user>/.local/state/arachne-tls/ca-cert.pem
#
# Invariants this file must preserve (SPEC §6):
#   - bind ONLY the tailnet address — never 0.0.0.0, never a LAN/public interface
#   - certificates via DNS-01 (no public HTTP challenge listener)
#   - verified HTTPS to the loopback backend (private CA), matching Tailscale Serve

arachne.pythagora.net {
	bind @@TAILNET_IPV4@@
	encode zstd gzip
	tls {
		dns cloudflare {env.CLOUDFLARE_API_TOKEN}
		resolvers 1.1.1.1 1.0.0.1
	}
	reverse_proxy https://127.0.0.1:8788 {
		transport http {
			tls_trust_pool file @@ARACHNE_CA_FILE@@
			tls_server_name localhost
		}
	}
}

# Optional: front the MCP adapter on the same name. Uncomment only if remote
# harnesses should reach MCP via the custom domain; then add
# `arachne.pythagora.net:8443` to ARACHNE_MCP_ALLOWED_HOSTS.
